#!/usr/bin/env bash
# Pre-commit: auto-format staged .nix files with nixfmt.
# Bypass with `git commit --no-verify`.

set -euo pipefail

STAGED_NIX=$(git diff --cached --name-only --diff-filter=ACM | grep -E '\.nix$' || true)

if [ -z "$STAGED_NIX" ]; then
  exit 0
fi

echo "→ nixfmt (auto-fix)"
while IFS= read -r f; do
  nix run --quiet nixpkgs#nixfmt-rfc-style -- "$f"
  git add "$f"
done <<< "$STAGED_NIX"

echo "✓ pre-commit checks complete"
