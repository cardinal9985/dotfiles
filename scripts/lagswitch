#!/usr/bin/env bash
# Drop the default-route interface for a short window. Hold-style mode using
# a fixed duration since KDE shortcuts don't natively fire on key-release.
# Tap = brief lag. Repeat-tap = extend.

set -euo pipefail

# Optional notification - works if libnotify is installed, no-op otherwise.
notify() {
  command -v notify-send >/dev/null && notify-send "$@" || true
}

DURATION="${LAGSWITCH_DURATION:-1.5}"
IFACE="$(ip route show default | awk '{print $5; exit}')"

if [ -z "$IFACE" ]; then
  notify -i network-disconnect "lagswitch" "no default interface found"
  exit 1
fi

# Mutex so rapid taps don't double-fire and leave the link down.
LOCK="/tmp/lagswitch.lock"
exec 9>"$LOCK"
if ! flock -n 9; then
  exit 0
fi

notify -i network-disconnect -t 1500 "LAG ON" "$IFACE down ${DURATION}s"
sudo ip link set "$IFACE" down
sleep "$DURATION"
sudo ip link set "$IFACE" up
notify -i network-transmit -t 1000 "LAG OFF" "$IFACE up"
